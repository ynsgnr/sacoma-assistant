{
  "domain": "sacoma_scale",
  "name": "SACOMA Smart Scale",
  "codeowners": ["@ynsgnr"],
  "config_flow": true,
  "dependencies": ["bluetooth_adapters"],
  "documentation": "https://github.com/ynsgnr/sacoma-assistant",
  "integration_type": "device",
  "iot_class": "local_push",
  "issue_tracker": "https://github.com/ynsgnr/sacoma-assistant/issues",
  "bluetooth": [
    {
      "service_uuid": "0000ffb0-0000-1000-8000-00805f9b34fb",
      "connectable": true
    },
    {
      "local_name": "MY_SCALE",
      "connectable": true
    }
  ],
  "requirements": ["sacoma-lib==0.1.0", "bleak-retry-connector>=3.5.0"],
  "version": "0.1.0"
}
